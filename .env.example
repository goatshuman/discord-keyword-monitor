# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Your Discord user ID (who receives DMs)
DISCORD_USER_ID=862948964408197120

# Comma-separated keywords to watch for (case-insensitive)
# Example: KEYWORDS=free,giveaway,available,drop
KEYWORDS=your_keyword_here

# Channel IDs to monitor (comma-separated)
MONITOR_CHANNELS=1276133271322886270,1276133271322886271
